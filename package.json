{
  "name": "sapere",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "get-inputs": "node scratch/read_last_user_input.js",
    "gen-5d": "node scratch/generateYear12Ch5DQuestions.js",
    "sync-seeds": "node scratch/dump_db_to_seeds.js",
    "seed": "node --import ./scripts/extResolve.mjs scratch/seed.js",
    "validate-seeds": "node --import ./scripts/extResolve.mjs scripts/validateSeeds.mjs",
    "test:mc-shuffle": "node scripts/testMcOptionShuffle.mjs",
    "test:mc-guard": "node scripts/checkMcShuffleUsage.mjs",
    "test:mc": "npm run test:mc-shuffle && npm run test:mc-guard && npm run test:answer-displays",
    "test:answer-displays": "node --import ./scripts/extResolve.mjs scripts/testAnswerDisplays.mjs",
    "audit:mc-seeds": "node --import ./scripts/extResolve.mjs scripts/auditMcSeedAnswers.mjs",
    "audit:mc-key-vs-solution": "node --import ./scripts/extResolve.mjs scripts/auditMcKeyVsSolution.mjs",
    "test:secret-note-bonus": "node --import ./scripts/extResolve.mjs scripts/testSecretNoteBonus.mjs",
    "test:secret-note-gradability": "node --import ./scripts/extResolve.mjs scripts/testSecretNoteGradability.mjs",
    "test:secret-note": "npm run test:secret-note-bonus && npm run test:secret-note-gradability",
    "test:teacher-review-subs": "node --import ./scripts/extResolve.mjs scripts/testTeacherReviewSubQuestions.mjs"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "3d-force-graph": "^1.80.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "jsdom": "^29.1.1",
    "jsxgraph": "^1.12.2",
    "katex": "^0.17.0",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^1.17.0",
    "mathlive": "^0.110.0",
    "nodemailer": "^8.0.7",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-sketch-canvas": "^6.2.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "puppeteer": "^25.1.0",
    "vite": "^8.0.10"

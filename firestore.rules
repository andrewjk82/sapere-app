rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email.lower() == "andrewjk82@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Students (tutor-managed records)
    // Tutors can only access their own students; admin can access all
    match /students/{studentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.tutorId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.tutorId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.tutorId == request.auth.uid);

      match /hsc_results/{resultId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }

      // Stat subcollections (daily_stats, calc_stats, detail_snapshot, etc.)
      // for manually-managed students — admin and the owning tutor.
      match /{document=**} {
        allow read, write: if isAdmin()
          || (isSignedIn()
            && get(/databases/$(database)/documents/students/$(studentId)).data.tutorId == request.auth.uid);
      }
    }

    // Sessions (lesson sessions)
    match /sessions/{sessionId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.tutorId == request.auth.uid)
        || (isSignedIn() && resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.tutorId == request.auth.uid);
    }

    // Questions — read for all authenticated users, write only for admin
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Per-chapter question ID index (question_index/{chapterId}) — lets the
    // daily assignment sample uniformly at random without scanning the bank.
    match /question_index/{chapterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reports — students can file (create), admin manages
    match /reports/{reportId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Grading queue — students submit (create), admin reviews
    match /grading_queue/{queueId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Study materials — read for all, write for admin only
    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Curriculum — read for all, write for admin only
    match /curriculum/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // System config — read for all authenticated, write for admin only
    match /system_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // System logs — read for admin only (used in Dashboard sync display)
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // written by server only
    }

    // Tiny cache invalidation documents used before loading larger datasets.
    match /sync_meta/{metaId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // One document per day with per-student challenge completion summaries.
    match /admin_daily_summary/{dateId} {
      allow read: if isAdmin();
      allow write: if isSignedIn();
    }

    // User profiles and their subcollections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      match /daily_stats/{statId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

        match /detail_snapshot/{snapshotId} {
          allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        }

        // Per-question working-out images stored as a sibling subcollection
        // so the parent record stays under Firestore's 1 MB document limit.
        match /working_out/{idx} {
          allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        }
      }

      match /daily_assignments/{assignmentId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }

      match /calc_stats/{statId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

        match /detail_snapshot/{snapshotId} {
          allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        }

        match /working_out/{idx} {
          allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        }
      }

      match /chapterProgress/{progressId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }

      // Seen-question tracking for daily assignment de-duplication. Without
      // this match the subcollection was unreachable and the seen filter
      // silently never worked.
      match /seen_questions/{docId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }

      // Per-student question pool (chapter-balanced daily selection + accuracy).
      match /practice_pool/{docId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }

      // Daily Calculation auto-mode progress (per-group adaptive levelling).
      // Teacher (admin) configures it; the student app reads/writes its own.
      match /calc_progress/{docId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }

      // Exam Prep cross-device state (stats + history). Without this match the
      // subcollection was unreachable, so persistStateToServer silently failed
      // and the D-1 report always saw zero activity.
      match /examPrep/{docId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      }

      match /hsc_results/{resultId} {
        allow read: if isAdmin()
          || (isSignedIn()
            && request.auth.uid == userId
            && get(/databases/$(database)/documents/users/$(userId)).data.showHscGraph == true);
        allow write: if isAdmin();
      }

      match /notifications/{notifId} {
        allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
        allow create: if isSignedIn()
          && userId == "MeohP8s0LkPWSTWgEbzc7uaWVEG2"
          && request.resource.data.type == "challenge_completed"
          && request.resource.data.studentId == request.auth.uid;
      }
    }

    // Leaderboard entries
    match /leaderboard/{entryId} {
      allow read: if isSignedIn();
      // Allow user to write their own entry, or admin to write any entry
      // For manual students (id starts with 'manual-'), we allow tutors to manage them
      allow write: if isAdmin() 
        || (isSignedIn() && request.auth.uid == entryId)
        || (isSignedIn() && entryId[0:7] == "manual-");
    }
  }
}
